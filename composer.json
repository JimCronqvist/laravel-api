{
  "name": "cronqvist/laravel-api",
  "description": "A Laravel package for creating REST APIs. Tightly integrated with Spatie and Laravel Passport",
  "keywords": ["laravel-api", "api", "laravel"],
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Jim Cronqvist",
      "email": "jim.cronqvist@gmail.com"
    }
  ],
  "require" : {
    "php": "^8.0",
    "ext-json": "*",
    "laravel/framework": "^8.0|^9.0|^10.0|^11.0|^12.0",
    "laravel/passport": "^10.1.0|^11.0|^12.0",
    "spatie/laravel-query-builder": "^5.1|^6.0",
    "phpdocumentor/reflection-docblock": "^5.0|^6.0",
    "lcobucci/jwt": "^4.3"
  },
  "suggest": {
    "spatie/laravel-medialibrary": "Required to use Media functionality",
    "laravel/passport": "Required to use Passport functionality",
    "spatie/laravel-permission": "Highly recommended to effectively handle the built in gates with an RBAC style permission system"
  },
  "conflict": {
    "spatie/laravel-medialibrary": "<11.0.0",
    "spatie/laravel-permission": "<6.0.0",
    "laravel/passport": "<10.1.0",
    "league/oauth2-server": "<8.3.2"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Cronqvist\\Api\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Cronqvist\\Api\\ApiServiceProvider"
      ]
    }
  }
}
